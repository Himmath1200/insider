# Netlify - files and directories to ignore

# Python (don't deploy Python code)
*.py
*.pyc
__pycache__/
*.egg-info/
venv/

# Flask (don't deploy Flask files)
instance/
flask_session/

# Git (don't deploy git files)
.git
.gitignore
.gitattributes

# IDE (don't deploy IDE settings)
.vscode
.idea
*.swp
*.swo

# OS (don't deploy OS files)
.DS_Store
Thumbs.db

# Node (don't deploy node modules)
node_modules/
package-lock.json

# Database (don't deploy databases)
*.db
*.sqlite

# Documentation (optional - keep for reference)
# *.md

# Build artifacts
build/
dist/

# Other (don't deploy these)
.env
.env.example
Procfile
runtime.txt
requirements.txt
setup-deployment.sh

